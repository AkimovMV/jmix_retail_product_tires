<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1" author="retail-product-tires">
        <createTable tableName="TIRE">
            <column name="ID" type="VARCHAR(30)">
                <constraints nullable="false" primaryKey="true" primaryKeyName="PK_TIRE"/>
            </column>
            <column name="NAME" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="PRODUCER_ARTICLE_ID" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="WIDTH" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="WIDTH_ID_1C" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="HEIGHT" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="HEIGHT_ID_1C" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="DIAMETER" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="DIAMETER_ID_1C" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="DIAMETER_OUT" type="VARCHAR(50)"/>
            <column name="DIAMETER_OUT_ID_1C" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="SEASON" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="THORN" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="CATEGORY" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="CATEGORY_ID_1C" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="HOMOLOGATION" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="TECHNOLOGY" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="SPEED_INDEX" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="SPEED_INDEX_ID_1C" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="VERSION" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>